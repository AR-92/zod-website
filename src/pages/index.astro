---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { Zap, FlaskConical, Check, ArrowUpRight, ArrowRight, Monitor, Layers, Wrench, Lightbulb, ShieldCheck, Activity, Globe, ChevronDown, ChevronUp, Plus, Minus, Star, Quote, Users, FileText, MessageSquare, Code, Server } from 'lucide-astro';
---

<BaseLayout>
  <div class="isolate bg-white dark:bg-gray-950">
    <Navbar />
    <main class="flex min-h-dvh flex-col pt-14">
      <div data-scheme="dark">
        <div class="grid flex-1 grid-rows-[1fr_auto] overflow-clip grid-cols-[1fr_var(--gutter-width)_minmax(0,var(--breakpoint-2xl))_var(--gutter-width)_1fr] [--gutter-width:--spacing(6)] lg:[--gutter-width:--spacing(10)]">
          <div class="col-start-2 row-span-full row-start-1 max-sm:hidden border-x border-x-(--grid-line-color) bg-size-[10px_10px] bg-fixed bg-[repeating-linear-gradient(315deg,var(--grid-line-color)_0,var(--grid-line-color)_1px,transparent_0,transparent_50%)]">
          </div>
          <div class="col-start-4 row-span-full row-start-1 max-sm:hidden border-x border-x-(--grid-line-color) bg-size-[10px_10px] bg-fixed bg-[repeating-linear-gradient(315deg,var(--grid-line-color)_0,var(--grid-line-color)_1px,transparent_0,transparent_50%)]">
          </div>
          <div class="col-start-3 row-start-1 max-sm:col-span-full max-sm:col-start-1">
            {/* Hero Section */}
            <div class="line-t mt-12 grid gap-x-10 max-lg:gap-y-5 sm:mt-20 lg:mt-24 lg:grid-cols-2">
              <div class="px-4 py-2 max-lg:line-b sm:px-2 lg:border-r lg:border-(--grid-line-color)">
                <div class="flex items-center gap-2">
                  <p class="font-mono text-[0.8125rem]/6 font-medium tracking-widest text-pretty uppercase text-gray-600 dark:text-gray-400">
                    AI Agent Platform
                  </p>
                </div>
                <h1 class="mt-2 text-6xl tracking-tighter sm:text-8xl text-pretty">
                  Zod
                </h1>
              </div>
              <div class="flex items-center px-4 py-2 max-lg:line-y max-lg:row-start-3 sm:px-2 lg:border-l lg:border-(--grid-line-color)">
                <p class="max-w-2xl text-lg/7 font-medium text-pretty text-gray-600 dark:text-gray-400">
                  A modular AI agent platform with a core engine that handles AI orchestration — from tool execution to policy enforcement to workflow management.
                </p>
              </div>
              <div class="flex items-center px-4 py-2 max-lg:line-y max-lg:row-start-2 sm:px-2 lg:border-t lg:border-r lg:border-(--grid-line-color)">
                <div class="flex flex-wrap gap-10">
                  <div class="flex items-center gap-3 text-sm/6 font-semibold text-gray-950 dark:text-white">
                    <Zap class="size-8 flex-none stroke-current text-gray-400" />
                    JavaScript
                  </div>
                  <div class="flex items-center gap-3 text-sm/6 font-semibold text-gray-950 dark:text-white">
                    <FlaskConical class="size-8 flex-none stroke-current text-gray-400" />
                    TypeScript
                  </div>
                </div>
              </div>
              <div class="flex flex-wrap gap-4 px-4 py-2 max-lg:line-t max-lg:row-start-4 max-lg:mt-3 sm:px-2 lg:border-t lg:border-l lg:border-(--grid-line-color)">
                <a class="shrink-0 gap-2 inline-flex justify-center rounded-full text-sm/6 font-semibold focus-visible:outline-2 focus-visible:outline-offset-2 bg-gray-950 text-white hover:bg-gray-800 focus-visible:outline-gray-950 dark:bg-gray-700 dark:hover:bg-gray-600 dark:text-white dark:hover:bg-gray-200 dark:focus-visible:outline-white px-4 py-2" href="https://app.zodagent.com/" target="_blank">
                  Try Demo
                  <ArrowUpRight class="-mr-0.5 w-2.5" />
                </a>
                <a class="shrink-0 gap-2 inline-flex justify-center rounded-full text-sm/6 font-semibold ring-1 text-gray-950 ring-gray-950/10 hover:ring-gray-950/20 dark:text-white dark:ring-white/10 dark:hover:ring-white/20 px-4 py-2" href="https://docs.zodagent.com/">
                  Documentation
                  <ArrowRight class="-mr-0.5 w-2.5 fill-gray-600 dark:fill-gray-400" />
                </a>
                <div class="flex-1">
                </div>
              </div>
            </div>

            {/* Hero Images */}
            <div class="line-b-screen line-y bg-black/1 p-2 dark:bg-white/5">
              <div class="grid grid-cols-2 gap-2 sm:aspect-1520/740 sm:grid-cols-3 sm:grid-rows-2">
                <div class="col-span-2 aspect-1010/740 overflow-hidden rounded-2xl outline -outline-offset-1 outline-black/10 sm:row-span-2 dark:outline-white/10">
                  <img alt="Zod Platform" class="size-full rounded-2xl object-cover in-data-[scheme=dark]:hidden in-data-[scheme=system]:dark:hidden" src="https://images.unsplash.com/photo-1555949963-aa79d84cee6c?w=1011&h=724&fit=crop"/>
                  <img alt="Zod Platform" class="size-full rounded-2xl object-cover in-data-[scheme=light]:hidden in-data-[scheme=system]:not-dark:hidden" src="https://images.unsplash.com/photo-1555949963-aa79d84cee6c?w=1011&h=724&fit=crop&bg=1a1a1a"/>
                </div>
                <div class="aspect-501/366 overflow-hidden rounded-2xl outline -outline-offset-1 outline-black/10 dark:outline-white/10">
                  <img alt="Zod Interface" class="size-full rounded-2xl object-cover in-data-[scheme=dark]:hidden in-data-[scheme=system]:dark:hidden" src="https://images.unsplash.com/photo-1551288049-bebda4e02f72?w=501&h=358&fit=crop"/>
                  <img alt="Zod Interface" class="size-full rounded-2xl object-cover in-data-[scheme=light]:hidden in-data-[scheme=system]:not-dark:hidden" src="https://images.unsplash.com/photo-1551288049-bebda4e02f72?w=501&h=358&fit=crop&bg=1a1a1a"/>
                </div>
                <div class="aspect-501/366 overflow-hidden rounded-2xl outline -outline-offset-1 outline-black/10 dark:outline-white/10">
                  <img alt="Zod Dashboard" class="size-full rounded-2xl object-cover in-data-[scheme=dark]:hidden in-data-[scheme=system]:dark:hidden" src="https://images.unsplash.com/photo-1518770660439-4636190af475?w=501&h=358&fit=crop"/>
                  <img alt="Zod Dashboard" class="size-full rounded-2xl object-cover in-data-[scheme=light]:hidden in-data-[scheme=system]:not-dark:hidden" src="https://images.unsplash.com/photo-1518770660439-4636190af475?w=501&h=358&fit=crop&bg=1a1a1a"/>
                </div>
              </div>
            </div>

            {/* Main Content Sections */}
            <div class="mt-16 lg:mt-24">
            </div>
            <div class="mt-16 grid grid-cols-1 gap-y-16 lg:mt-24 lg:grid-cols-[1fr_2.5rem_3fr] lg:gap-y-24 xl:grid-cols-[1fr_2.5rem_2fr]">
              <div class="col-start-2 row-span-5 row-start-1 border-x border-(--grid-line-color) max-lg:hidden">
              </div>

              {/* What's Included Section */}
              <section class="line-y col-span-full row-start-1 grid grid-cols-subgrid py-2">
                <p class="font-mono text-[0.8125rem]/6 font-medium tracking-widest text-pretty uppercase text-gray-600 dark:text-gray-400 min-[105rem]:absolute min-[105rem]:top-0 min-[105rem]:-left-10 min-[105rem]:origin-bottom-right min-[105rem]:-translate-x-full min-[105rem]:-translate-y-full min-[105rem]:-rotate-90 min-[105rem]:pr-2 max-[105rem]:hidden">
                  Built for developers
                </p>
                <h2 class="px-4 text-2xl/10 font-medium tracking-tight sm:px-2">
                  What's included
                </h2>
                <div class="col-start-3 px-4 max-lg:mt-2 sm:px-2">
                  <div class="max-w-2xl grid grid-cols-1 gap-6 text-sm/7 text-gray-600 dark:text-gray-400">
                    <p>
                      Zod is a modular AI agent platform built for developers who want to build AI-powered applications. Designed for flexibility and control, with everything you need to create powerful AI assistants.
                    </p>
                    <p>
                      From simple chatbots to complex autonomous agents, Zod provides the building blocks. Mix and match capabilities to create exactly what you need — no bloat, no compromises.
                    </p>
                    <p>
                      Whether you're building a customer support system, a coding assistant, or a full automation platform, Zod scales with your needs.
                    </p>
                  </div>
                  <div class="mt-10 grid grid-cols-1 gap-10 max-xl:max-w-2xl lg:mt-15 xl:grid-cols-2 text-sm/7 text-gray-600 dark:text-gray-400">
                    <p>
                      <strong class="font-semibold text-gray-950 dark:text-white">
                        Built by experts
                      </strong>
                      — designed by developers who understand AI systems inside and out, with a focus on reliability and safety.
                    </p>
                    <p>
                      <strong class="font-semibold text-gray-950 dark:text-white">
                        Extensible
                      </strong>
                      — add new capabilities through extensions, tools, and skills that integrate seamlessly with the core engine.
                    </p>
                    <p>
                      <strong class="font-semibold text-gray-950 dark:text-white">
                        Safety first
                      </strong>
                      — built-in policy enforcement, budget limits, step limits, and approval gating keep your AI controlled.
                    </p>
                    <p>
                      <strong class="font-semibold text-gray-950 dark:text-white">
                        Real-time streaming
                      </strong>
                      — see what your AI is thinking as it thinks it, with full event logging and debugging.
                    </p>
                    <p>
                      <strong class="font-semibold text-gray-950 dark:text-white">
                        Multi-provider
                      </strong>
                      — connect to OpenAI, Anthropic, Google, and any OpenAI-compatible API.
                    </p>
                    <p>
                      <strong class="font-semibold text-gray-950 dark:text-white">
                        Open source
                      </strong>
                      — free to use, modify, and extend. Built in public, for the community.
                    </p>
                  </div>
                </div>
              </section>

              {/* Screenshots Section */}
              <section class="line-y col-span-full row-start-2 grid grid-cols-subgrid py-2">
                <h2 class="px-4 text-2xl/10 font-medium tracking-tight sm:px-2">
                  Screenshots
                </h2>
                <div class="col-start-3 grid grid-cols-1 gap-4 px-4 py-2 max-lg:mt-2 sm:grid-cols-2">
                  <img alt="" class="aspect-768/492 w-full rounded-md outline outline-gray-950/10 in-data-[scheme=dark]:hidden sm:rounded-xl dark:outline-white/20 in-data-[scheme=system]:dark:hidden" height="492" src="https://images.unsplash.com/photo-1620712943543-bcc4688e7485?w=768&h=492&fit=crop" width="768"/>
                  <img alt="" class="aspect-768/492 w-full rounded-md outline outline-gray-950/10 in-data-[scheme=dark]:hidden sm:rounded-xl dark:outline-white/20 in-data-[scheme=system]:dark:hidden" height="492" src="https://images.unsplash.com/photo-1551288049-bebda4e02f72?w=768&h=492&fit=crop" width="768"/>
                  <img alt="" class="aspect-768/492 w-full rounded-md outline outline-gray-950/10 in-data-[scheme=dark]:hidden sm:rounded-xl dark:outline-white/20 in-data-[scheme=system]:dark:hidden" height="492" src="https://images.unsplash.com/photo-1518770660439-4636190af475?w=768&h=492&fit=crop" width="768"/>
                  <img alt="" class="aspect-768/492 w-full rounded-md outline outline-gray-950/10 in-data-[scheme=dark]:hidden sm:rounded-xl dark:outline-white/20 in-data-[scheme=system]:dark:hidden" height="492" src="https://images.unsplash.com/photo-1555949963-aa79d84cee6c?w=768&h=492&fit=crop" width="768"/>
                  <img alt="" class="aspect-768/492 w-full rounded-md outline outline-gray-950/10 in-data-[scheme=light]:hidden sm:rounded-xl dark:outline-white/20 in-data-[scheme=system]:not-dark:hidden" height="492" src="https://images.unsplash.com/photo-1620712943543-bcc4688e7485?w=768&h=492&fit=crop&bg=1a1a1a" width="768"/>
                  <img alt="" class="aspect-768/492 w-full rounded-md outline outline-gray-950/10 in-data-[scheme=light]:hidden sm:rounded-xl dark:outline-white/20 in-data-[scheme=system]:not-dark:hidden" height="492" src="https://images.unsplash.com/photo-1551288049-bebda4e02f72?w=768&h=492&fit=crop&bg=1a1a1a" width="768"/>
                  <img alt="" class="aspect-768/492 w-full rounded-md outline outline-gray-950/10 in-data-[scheme=light]:hidden sm:rounded-xl dark:outline-white/20 in-data-[scheme=system]:not-dark:hidden" height="492" src="https://images.unsplash.com/photo-1518770660439-4636190af475?w=768&h=492&fit=crop&bg=1a1a1a" width="768"/>
                  <img alt="" class="aspect-768/492 w-full rounded-md outline outline-gray-950/10 in-data-[scheme=light]:hidden sm:rounded-xl dark:outline-white/20 in-data-[scheme=system]:not-dark:hidden" height="492" src="https://images.unsplash.com/photo-1555949963-aa79d84cee6c?w=768&h=492&fit=crop&bg=1a1a1a" width="768"/>
                </div>
              </section>

              {/* Technology Section */}
              <section class="line-y col-span-full row-start-3 grid grid-cols-subgrid py-2">
                <h2 class="px-4 text-2xl/10 font-medium tracking-tight sm:px-2">
                  The technology
                </h2>
                <div class="col-start-3 px-4 max-lg:mt-2 sm:px-2">
                  <div class="grid grid-cols-1 gap-10 text-sm/7 text-gray-600 dark:text-gray-400 lg:grid-cols-2">
                    <div class="flex items-start gap-4">
                      <div class="mt-1 flex size-10 shrink-0 items-center justify-center rounded-xl bg-sky-500/10 text-sky-500">
                        <Monitor class="size-5" />
                      </div>
                      <div>
                        <h3 class="font-semibold text-gray-950 dark:text-white">
                          AgentHarness Core
                        </h3>
                        <p class="mt-1">
                          A robust orchestrator that manages conversation history, tool selection, and response generation with full lifecycle awareness.
                        </p>
                      </div>
                    </div>
                    <div class="flex items-start gap-4">
                      <div class="mt-1 flex size-10 shrink-0 items-center justify-center rounded-xl bg-purple-500/10 text-purple-500">
                        <Layers class="size-5" />
                      </div>
                      <div>
                        <h3 class="font-semibold text-gray-950 dark:text-white">
                          Extension System
                        </h3>
                        <p class="mt-1">
                          Modular components that add capabilities — from AI providers to storage to custom integrations.
                        </p>
                      </div>
                    </div>
                    <div class="flex items-start gap-4">
                      <div class="mt-1 flex size-10 shrink-0 items-center justify-center rounded-xl bg-emerald-500/10 text-emerald-500">
                        <Wrench class="size-5" />
                      </div>
                      <div>
                        <h3 class="font-semibold text-gray-950 dark:text-white">
                          Tools
                        </h3>
                        <p class="mt-1">
                          File operations, shell commands, web fetch, database queries, and more — all with safety guards.
                        </p>
                      </div>
                    </div>
                    <div class="flex items-start gap-4">
                      <div class="mt-1 flex size-10 shrink-0 items-center justify-center rounded-xl bg-amber-500/10 text-amber-500">
                        <Lightbulb class="size-5" />
                      </div>
                      <div>
                        <h3 class="font-semibold text-gray-950 dark:text-white">
                          Skills
                        </h3>
                        <p class="mt-1">
                          Define how the AI thinks and communicates — expert personas for code review, support, analysis, and more.
                        </p>
                      </div>
                    </div>
                    <div class="flex items-start gap-4">
                      <div class="mt-1 flex size-10 shrink-0 items-center justify-center rounded-xl bg-pink-500/10 text-pink-500">
                        <ShieldCheck class="size-5" />
                      </div>
                      <div>
                        <h3 class="font-semibold text-gray-950 dark:text-white">
                          Safety & Policy
                        </h3>
                        <p class="mt-1">
                          Budget limits, step limits, loop detection, and approval gating keep your AI usage controlled and predictable.
                        </p>
                      </div>
                    </div>
                    <div class="flex items-start gap-4">
                      <div class="mt-1 flex size-10 shrink-0 items-center justify-center rounded-xl bg-cyan-500/10 text-cyan-500">
                        <Activity class="size-5" />
                      </div>
                      <div>
                        <h3 class="font-semibold text-gray-950 dark:text-white">
                          Real-time Events
                        </h3>
                        <p class="mt-1">
                          Stream AI responses, see tool calls as they happen — full observability for debugging.
                        </p>
                      </div>
                    </div>
                  </div>
                </div>
              </section>

              {/* Open Source Section */}
              <section class="line-y col-span-full row-start-4 grid grid-cols-subgrid py-2">
                <h2 class="px-4 text-2xl/10 font-medium tracking-tight sm:px-2">
                  Open source
                </h2>
                <div class="col-start-3 px-4 max-lg:mt-2 sm:px-2">
                  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                    <div class="rounded-2xl border border-gray-950/5 p-6 dark:border-white/10">
                      <div class="flex items-center gap-3">
                        <Globe class="size-6 text-gray-400" />
                        <h3 class="font-semibold text-gray-950 dark:text-white">
                          zod-harness
                        </h3>
                      </div>
                      <p class="mt-2 text-sm/6 text-gray-600 dark:text-gray-400">
                        Core engine for AI orchestration. Manages the agent loop, tool execution, and policy enforcement.
                      </p>
                      <a class="mt-3 inline-flex items-center gap-1 text-sm/6 font-medium text-sky-500 hover:text-sky-600" href="https://github.com/AR-92/zod-harness">
                        View on GitHub
                        <ArrowRight class="ml-0.5 size-3" />
                      </a>
                    </div>
                    <div class="rounded-2xl border border-gray-950/5 p-6 dark:border-white/10">
                      <div class="flex items-center gap-3">
                        <Monitor class="size-6 text-gray-400" />
                        <h3 class="font-semibold text-gray-950 dark:text-white">
                          zod-client
                        </h3>
                      </div>
                      <p class="mt-2 text-sm/6 text-gray-600 dark:text-gray-400">
                        Browser interface built with SolidJS. Real-time chat, model selection, and event debugging.
                      </p>
                      <a class="mt-3 inline-flex items-center gap-1 text-sm/6 font-medium text-sky-500 hover:text-sky-600" href="https://github.com/AR-92/zod-client">
                        View on GitHub
                        <ArrowRight class="ml-0.5 size-3" />
                      </a>
                    </div>
                  </div>
                </div>
              </section>

              {/* Pricing Section */}
              <section class="col-span-full mt-40" id="pricing">
                <div class="line-y grid grid-cols-1 gap-x-10 lg:grid-cols-2 lg:grid-rows-[1fr_auto]">
                  <div class="col-start-1 row-start-1 flex flex-col gap-5 lg:border-r lg:border-(--grid-line-color) lg:pb-10">
                    <div class="grid grid-cols-1 gap-y-2 px-4 py-2 max-lg:line-b sm:px-2 lg:line-b/half">
                      <h2 class="font-mono text-[0.8125rem]/6 font-medium tracking-widest text-pretty uppercase text-gray-600 dark:text-gray-400 min-[105rem]:absolute min-[105rem]:top-0 min-[105rem]:-left-10 min-[105rem]:origin-bottom-right min-[105rem]:-translate-x-full min-[105rem]:-translate-y-full min-[105rem]:-rotate-90 min-[105rem]:pr-2">
                        Pricing
                      </h2>
                      <p class="text-[2.5rem]/none font-medium tracking-tight text-pretty">
                        Free and open source.
                      </p>
                    </div>
                    <div class="px-4 py-2 max-lg:line-y sm:px-2 lg:line-y/half">
                      <p class="max-w-2xl text-sm/7 text-gray-600 dark:text-gray-400">
                        Zod is completely free to use, modify, and distribute under the MIT license. Use it for as many projects as you need.
                      </p>
                    </div>
                    <div class="px-4 py-2 max-lg:line-y sm:px-2 lg:line-y/half">
                      <div class="flex flex-wrap gap-10">
                        <div class="flex items-center gap-3 text-sm/6 font-semibold text-gray-950 dark:text-white">
                          <Code class="size-8 flex-none stroke-current text-gray-400" />
                          MIT License
                        </div>
                        <div class="flex items-center gap-3 text-sm/6 font-semibold text-gray-950 dark:text-white">
                          <Server class="size-8 flex-none stroke-current text-gray-400" />
                          Community Driven
                        </div>
                      </div>
                    </div>
                  </div>
                  <div class="max-lg:line-t max-lg:mt-10 lg:col-start-2 lg:row-span-2 bg-gray-950/5 py-[calc(--spacing(2)+1px)] dark:bg-white/5 max-lg:-mx-px max-lg:px-[calc(--spacing(2)+1px)] lg:-mr-px lg:border-l lg:border-(--grid-line-color) lg:pr-[calc(--spacing(2)+1px)] lg:pl-2">
                    <div class="grid grid-cols-1 gap-y-6 rounded-2xl bg-gray-950 p-6 sm:rounded-4xl sm:p-10 dark:bg-gray-950 dark:inset-ring dark:inset-ring-white/15">
                      <div class="flex flex-wrap items-start justify-between gap-x-4 gap-y-6">
                        <div>
                          <p class="text-gray-300 font-mono text-[0.8125rem]/6 font-medium tracking-widest text-pretty uppercase">
                            Get started with
                            <span class="sr-only">Zod</span>
                          </p>
                          <Globe class="mt-6 h-7 text-white" />
                        </div>
                      </div>
                      <div>
                        <div class="flex flex-wrap items-center justify-between gap-6">
                          <div class="flex items-center gap-x-4">
                            <p class="text-6xl font-light text-white *:font-medium">
                              Free
                            </p>
                            <div>
                              <p class="text-sm/6 font-semibold text-white">
                                forever
                              </p>
                              <p class="text-sm/6 text-gray-300">
                                no credit card required
                              </p>
                            </div>
                          </div>
                          <a aria-label="Get started for free" class="inline-flex justify-center rounded-full text-sm/6 font-semibold focus-visible:outline-2 focus-visible:outline-offset-2 bg-white text-gray-950 hover:bg-gray-200 focus-visible:outline-white dark:bg-gray-700 dark:hover:bg-gray-600 dark:text-white dark:hover:bg-gray-200 dark:focus-visible:outline-white px-4 py-2" href="https://app.zodagent.com/" target="_blank">
                            Get started
                          </a>
                        </div>
                      </div>
                      <p class="max-w-2xl text-sm/7 text-gray-300">
                        Full access to all core features, with no limitations on usage or projects. Build anything you can imagine.
                      </p>
                      <hr class="border-t-white/10"/>
                      <div class="@container">
                        <ul class="group grid grid-cols-1 gap-x-10 gap-y-6 text-sm/7 text-gray-600 data-dark:text-gray-300 @3xl:grid-cols-2 dark:text-gray-400" data-dark="true" role="list">
                          <li class="grid max-w-2xl grid-cols-[auto_1fr] gap-6">
                            <Check class="h-7 w-5.5 shrink-0 text-sky-500" />
                            <p>
                              <strong class="font-semibold text-gray-950 group-data-dark:text-white dark:text-white">
                                Unlimited projects
                              </strong>
                              — use Zod for as many projects as you need, both personal and commercial.
                            </p>
                          </li>
                          <li class="grid max-w-2xl grid-cols-[auto_1fr] gap-6">
                            <Check class="h-7 w-5.5 shrink-0 text-sky-500" />
                            <p>
                              <strong class="font-semibold text-gray-950 group-data-dark:text-white dark:text-white">
                                Open source
                              </strong>
                              — free to use, modify, and distribute under the permissive MIT license.
                            </p>
                          </li>
                          <li class="grid max-w-2xl grid-cols-[auto_1fr] gap-6">
                            <Check class="h-7 w-5.5 shrink-0 text-sky-500" />
                            <p>
