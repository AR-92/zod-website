---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
}

const { title = "Zod - Build, customize, and interact with AI agents" } = Astro.props;
---

<!doctype html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="overflow-x-hidden">
    <div class="isolate bg-white dark:bg-gray-950">
      <Navbar />

      <div class="grid min-h-dvh grid-cols-1 grid-rows-[1fr_1px_auto_1px_auto] pt-14 lg:grid-cols-[2.5rem_minmax(0,1fr)_2.5rem]">
        <div class="relative row-start-1 lg:col-start-2">
          <div class="mx-auto grid w-full max-w-2xl grid-cols-1 gap-10 px-4 pt-10 pb-24 xl:max-w-5xl">
            <slot />
          </div>
        </div>

        <div class="col-span-full col-start-2 row-start-2 h-px bg-gray-950/5 dark:bg-white/10"></div>

        <div class="row-start-3 lg:col-start-2">
          <Footer />
        </div>

        <div class="col-span-full col-start-2 row-start-4 h-px bg-gray-950/5 dark:bg-white/10"></div>

        <div class="row-start-5 grid lg:col-start-2">
          <div class="mx-auto flex w-full flex-col items-start gap-6 sm:flex-row sm:items-center sm:justify-between sm:gap-8 max-w-2xl lg:max-w-5xl px-2 py-10">
            <div class="flex flex-col gap-4 text-sm/6 text-gray-700 sm:flex-row sm:gap-2 sm:pr-4 dark:text-gray-400">
              <span>Copyright © 2026 NetAI Systems</span>
              <span class="max-sm:hidden">·</span>
              <a class="hover:underline" href="https://docs.zodagent.com/legal/trademark">Trademark Policy</a>
            </div>
            <div class="flex items-center gap-4">
              <a href="https://www.linkedin.com/in/zodagnet/" class="text-gray-600 hover:text-gray-950 dark:text-gray-400 dark:hover:text-white transition-colors">
                <svg class="size-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.047c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
