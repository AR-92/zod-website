        <path d="M13.73 4a2 2 0 0 0-3.46 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3z"/>
      </svg>
    </div>
    <div class="line-b mt-10 grid grid-cols-2 gap-x-8 gap-y-10 py-2 @3xl:grid-cols-4">
      <div>
        <h3 class="text-sm/7 font-semibold dark:text-white">Zod</h3>
        <ul role="list" class="mt-4 flex flex-col gap-y-4">
          <li class="group">
            <a class="text-sm/7 text-gray-600 hover:text-gray-950 dark:text-gray-400 dark:hover:text-white" href="https://www.zodagent.com/">Home</a>
