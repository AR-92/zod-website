          </li>
        </ul>
      </div>
      <div>
        <h3 class="text-sm/7 font-semibold dark:text-white">Resources</h3>
        <ul role="list" class="mt-4 flex flex-col gap-y-4">
          <li class="group">
            <a class="text-sm/7 text-gray-600 hover:text-gray-950 dark:text-gray-400 dark:hover:text-white" href="https://app.zodagent.com/">App</a>
