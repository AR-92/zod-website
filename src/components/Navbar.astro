---
// Navbar component - Reusable navbar matching Zod website theme
import { ChevronDown, Search, Ellipsis } from 'lucide-astro';
---

<div class="fixed inset-x-0 top-0 z-10 border-b border-black/5 dark:border-white/10">
  <div class="bg-white dark:bg-gray-950">
    <div class="flex h-14 items-center justify-between gap-8 px-4 sm:px-6">
      <div class="flex items-center gap-4">
        <a class="shrink-0" aria-label="Home" href="/">
          <img src="/favicon.svg" alt="Zod" class="h-5" />
        </a>
        <span class="text-lg font-semibold text-gray-950 dark:text-white">zod</span>
        <button class="flex items-center gap-0.5 rounded-2xl bg-gray-950/5 py-0.5 pr-1.5 pl-2.5 text-xs/5 font-medium text-gray-950 tabular-nums hover:bg-gray-950/7.5 dark:bg-white/10 dark:text-white dark:hover:bg-white/12.5" aria-label="Select version of library" type="button">
          v1.0
          <ChevronDown class="size-4 text-gray-400" />
        </button>
      </div>
      <div class="flex items-center gap-6 max-md:hidden">
        <button type="button" class="inline-flex items-center gap-1 rounded-full bg-gray-950/2 px-2 py-1 inset-ring inset-ring-gray-950/8 dark:bg-white/5 dark:inset-ring-white/2">
          <Search class="-ml-0.5 size-4 text-gray-600 dark:text-gray-500" />
          <kbd class="hidden font-sans text-xs/4 text-gray-500 dark:text-gray-400 [.os-macos_&]:block">⌘K</kbd>
          <kbd class="hidden font-sans text-xs/4 text-gray-500 not-[.os-macos_&]:block dark:text-gray-400">Ctrl&nbsp;K</kbd>
        </button>
        <a class="text-sm/6 text-gray-950 dark:text-white hover:opacity-80 transition-opacity" href="/">Home</a>
        <a class="text-sm/6 text-gray-950 dark:text-white hover:opacity-80 transition-opacity" href="https://docs.zodagent.com/">Docs</a>
        <a class="text-sm/6 text-gray-950 dark:text-white hover:opacity-80 transition-opacity" href="https://help.zodagent.com/">Help</a>
        <a class="text-sm/6 text-gray-950 dark:text-white hover:opacity-80 transition-opacity" href="https://blogs.zodagent.com/">Blog</a>
        <a href="https://app.zodagent.com/" class="group relative px-1.5 text-sm/6 text-cyan-700 dark:text-cyan-300">
          <span class="absolute inset-0 border border-dashed border-cyan-300/60 bg-cyan-400/10 group-hover:bg-cyan-400/15 dark:border-cyan-300/30"></span>
          Try Demo
          <svg width="5" height="5" viewBox="0 0 5 5" class="absolute top-[-2px] left-[-2px] fill-cyan-300 dark:fill-cyan-300/50"><path d="M2 0h1v2h2v1h-2v2h-1v-2h-2v-1h2z"></path></svg>
          <svg width="5" height="5" viewBox="0 0 5 5" class="absolute top-[-2px] right-[-2px] fill-cyan-300 dark:fill-cyan-300/50"><path d="M2 0h1v2h2v1h-2v2h-1v-2h-2v-1h2z"></path></svg>
          <svg width="5" height="5" viewBox="0 0 5 5" class="absolute bottom-[-2px] left-[-2px] fill-cyan-300 dark:fill-cyan-300/50"><path d="M2 0h1v2h2v1h-2v2h-1v-2h-2v-1h2z"></path></svg>
          <svg width="5" height="5" viewBox="0 0 5 5" class="absolute right-[-2px] bottom-[-2px] fill-cyan-300 dark:fill-cyan-300/50"><path d="M2 0h1v2h2v1h-2v2h-1v-2h-2v-1h2z"></path></svg>
        </a>
      </div>
      <div class="flex items-center gap-2.5 md:hidden">
        <button type="button" aria-label="Search" class="inline-grid size-7 place-items-center rounded-md">
          <Search class="size-4" />
        </button>
        <button type="button" class="relative inline-grid size-7 place-items-center rounded-md text-gray-950 hover:bg-gray-950/5 dark:text-white dark:hover:bg-white/10" aria-label="Navigation">
          <span class="absolute top-1/2 left-1/2 size-11 -translate-1/2 pointer-fine:hidden"></span>
          <Ellipsis class="size-4" />
        </button>
      </div>
    </div>
  </div>
</div>
